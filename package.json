{
  "name": "wcag-contrast-utils",
  "version": "1.0.1",
  "description": "A production-ready TypeScript utility for calculating contrast ratios and validating WCAG 2.1 color accessibility requirements.",
  "type": "module",
  "packageManager": "npm@11.6.1",
  "author": "Pavlo Golovatyy",
  "license": "MIT",
  "keywords": [
    "WCAG",
    "contrast",
    "accessibility",
    "color",
    "web",
    "design",
    "compliance",
    "a11y",
    "typescript",
    "color-contrast"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "build:check": "cross-env TSDOWN_VALIDATE_PACKAGE=true npm_config_cache=/tmp/wcag-contrast-utils-npm-cache tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build:check && npm run size",
    "prepack": "npm run build",
    "size": "size-limit",
    "pack:check": "npm pack --dry-run --ignore-scripts --cache /tmp/wcag-contrast-utils-npm-cache"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pavlogolovatyy/wcag-contrast-utils.git"
  },
  "homepage": "https://github.com/pavlogolovatyy/wcag-contrast-utils#readme",
  "bugs": {
    "url": "https://github.com/pavlogolovatyy/wcag-contrast-utils/issues"
  },
  "size-limit": [
    {
      "path": "dist/index.cjs",
      "limit": "10 KB"
    },
    {
      "path": "dist/index.mjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@eslint/js": "^9.38.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/node": "^24.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.38.0",
    "publint": "^0.3.18",
    "size-limit": "^11.2.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
